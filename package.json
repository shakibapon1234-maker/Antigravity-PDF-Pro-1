{
  "name": "antigravity-pdf-pro",
  "version": "1.0.0",
  "description": "Antigravity PDF Pro - Desktop Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win --x64",
    "build-nsis": "electron-builder --win nsis --x64",
    "build-msi": "electron-builder --win msi --x64",
    "build-portable": "electron-builder --win portable --x64",
    "build-all": "electron-builder --win nsis portable --x64",
    "server-only": "node server.js",
    "setup-libs": "node scripts/setup-libs.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "build": {
    "appId": "com.antigravity.pdf-pro",
    "productName": "Antigravity PDF Pro",
    "copyright": "Copyright © 2026 Antigravity",
    "directories": {
      "output": "dist"
    },
    "icon": "assets/icon.ico",
    "files": [
      "main.js",
      "server.js",
      "preload.js",
      "index.html",
      "style.css",
      "package.json",
      "core/**",
      "editor/**",
      "tools/**",
      "converters/**",
      "ui/**",
      "assets/**",
      "bin/**",
      "archive/index.json",
      "node_modules/**"
    ],
    "extraResources": [
      {
        "from": "bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": false,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false,
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Antigravity PDF Pro",
      "artifactName": "Install App.exe",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "menuCategory": "Antigravity",
      "include": "installer.nsh"
    },
    "msi": {
      "artifactName": "Antigravity-PDF-Pro-${version}-x64.msi",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "menuCategory": "Antigravity",
      "shortcutName": "Antigravity PDF Pro",
      "upgradeCode": "12345678-1234-1234-1234-123456789012",
      "oneClick": false,
      "perMachine": false
    },
    "portable": {
      "artifactName": "Start with double click.exe"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "shakibapon1234-maker",
        "repo": "Antigravity-PDF-Pro-1"
      }
    ]
  },
  "dependencies": {
    "@sentry/electron": "^7.13.0",
    "electron-log": "^5.4.4",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.0.0",
    "express": "^4.22.1",
    "multer": "^1.4.5-lts.1",
    "node-machine-id": "^1.1.12",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^3.11.174"
  },
  "devDependencies": {
    "@pdf-lib/fontkit": "^0.0.4",
    "@playwright/test": "^1.60.0",
    "bootstrap-icons": "^1.11.3",
    "docx": "^7.1.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "file-saver": "^2.0.5",
    "html2pdf.js": "^0.10.1",
    "jspdf": "^2.5.2",
    "jszip": "^3.10.1",
    "lucide": "^0.383.0",
    "mammoth": "^1.6.0",
    "pptxgenjs": "^4.0.1",
    "sortablejs": "^1.15.0",
    "tesseract.js": "^5.0.0",
    "vitest": "^4.1.8",
    "xlsx": "^0.18.5"
  }
}
